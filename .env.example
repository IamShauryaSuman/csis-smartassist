# ==============================================================================
# FRONTEND CONFIGURATION
# These variables are exposed to the browser via the NEXT_PUBLIC_ prefix.
# ==============================================================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── API & Auth ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"


# ==============================================================================
# BACKEND CONFIGURATION
# These variables are strictly server-side and never exposed to the browser.
# ==============================================================================

# ── Application Settings ──
FRONTEND_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAIN=goa.bits-pilani.ac.in

# ── Supabase (Admin) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM API Keys ──
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
OPENROUTER_API_KEY=your-openrouter-key

# ── Google Drive & Calendar (Service Account) ──
GOOGLE_SERVICE_ACCOUNT_JSON_B64=base64-encoded-service-account-json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# ── Gmail API (OAuth) ──
GMAIL_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your_client_secret"
GMAIL_REFRESH_TOKEN="1//your_refresh_token"
GMAIL_SENDER_ADDRESS="CSIS SmartAssist <smartassist.csis@gmail.com>"
